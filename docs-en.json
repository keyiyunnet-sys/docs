{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "My Documentation Site",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#1E40AF"
  },
  "favicon": "/favicon.svg",
  "layout": "api",
  "api": {
    "playground": {
      "mode": "show"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API Introduction",
            "pages": [
              "en/index",
              "en/api-reference/introduction"
            ]
          },
          {
            "group": "Text Series API",
            "pages": [
              "en/api-reference/text/gemini-chat"
            ]
          },
          {
            "group": "Image Series API",
            "pages": [
              {
                "group": "Navo Banana",
                "pages": [
                  "en/api-reference/image/navo-banana-create",
                  "en/api-reference/image/navo-banana-query"
                ]
              }
            ]
          },
          {
            "group": "Video Series API",
            "pages": [
              {
                "group": "Sora",
                "pages": [
                  "en/api-reference/video/sora-create",
                  "en/api-reference/video/sora-query"
                ]
              },
              {
                "group": "VEO",
                "pages": [
                  "en/api-reference/video/veo-create",
                  "en/api-reference/video/veo-query"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Quick Start",
            "pages": [
              "en/guides/quickstart"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "modeToggle": {
    "default": "light",
    "isHidden": false
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "search": {
    "prompt": "Search docs...",
    "disabled": true
  },
  "ai": {
    "disabled": true
  },
  "versions": [
    {
      "name": "简体中文",
      "url": "https://kyy.mintlify.app"
    },
    {
      "name": "English", 
      "url": "https://kyy.mintlify.app/en"
    }
  ],
  "css": ["styles.css"]
}