{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "我的文档站点",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#1E40AF"
  },
  "favicon": "/favicon.svg",
  "layout": "api",
  "api": {
    "playground": {
      "mode": "show"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API 介绍",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "文字系列 API",
            "pages": [
              "api-reference/text/gemini-chat"
            ]
          },
          {
            "group": "图片系列 API",
            "pages": [
              {
                "group": "Navo Banana",
                "pages": [
                  "api-reference/image/navo-banana-create",
                  "api-reference/image/navo-banana-query"
                ]
              }
            ]
          },
          {
            "group": "视频系列 API",
            "pages": [
              {
                "group": "Sora",
                "pages": [
                  "api-reference/video/sora-create",
                  "api-reference/video/sora-query"
                ]
              },
              {
                "group": "VEO",
                "pages": [
                  "api-reference/video/veo-create",
                  "api-reference/video/veo-query"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "快速开始",
            "pages": [
              "guides/quickstart"
            ]
          },
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "modeToggle": {
    "default": "light",
    "isHidden": false
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "search": false,
  "search": {
    "prompt": "搜索文档...",
    "disabled": true
  },
  "css": ["styles.css"]
}
