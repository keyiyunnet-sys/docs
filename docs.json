{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "我的文档站点",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#1E40AF"
  },
  "favicon": "/favicon.svg",
  "layout": "api",
  "api": {
    "playground": {
      "mode": "show"
    },
    "baseUrl": "https://zcbservice.aizfw.cn/kyyReactApiServer",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    }
  },
  "navigation": {
