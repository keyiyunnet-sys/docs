# Mintlify 文档项目 .gitignore

# ============================================
# Mintlify 相关
# ============================================

# Mintlify 构建缓存
.mintlify/
_mintlify/

# Mintlify 本地配置
.mint/


# ============================================
# Node.js 相关
# ============================================

# 依赖目录
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 包管理器锁文件（可选，团队协作时建议保留）
# package-lock.json
# yarn.lock
# pnpm-lock.yaml


# ============================================
# 操作系统相关
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*


# ============================================
# 编辑器和 IDE
# ============================================

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]


# ============================================
# 临时文件和日志
# ============================================

# 日志文件
*.log
logs/
*.log.*

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~

# 缓存
.cache/
*.cache


# ============================================
# 环境变量和配置
# ============================================

# 环境变量文件
.env
.env.local
.env.development
.env.test
.env.production
.env*.local

# 本地配置文件
config.local.js
config.local.json


# ============================================
# 构建输出
# ============================================

# 构建目录
dist/
build/
out/
.next/
.nuxt/

# 静态文件生成
public/generated/


# ============================================
# 测试相关
# ============================================

# 测试覆盖率
coverage/
.nyc_output/
*.lcov

# 测试结果
test-results/
junit.xml


# ============================================
# 文档草稿和临时文件
# ============================================

# 草稿文件
drafts/
*.draft.mdx
*.draft.md

# 临时笔记
notes/
TODO.md
NOTES.md

# 备份文件
*.bak
*.backup
*_backup.*


# ============================================
# 项目特定的说明文档（可选）
# ============================================

# 如果不想提交这些说明文档到仓库，取消下面的注释
# 项目分析文档.md
# 如何高效编辑文档.md
# 多语言配置说明.md
# 新模型文档生成指南.md
# 快速添加新模型文档.md
# Sora2文档说明.md


# ============================================
# AI 工具相关
# ============================================

# AI 工具配置（如果包含敏感信息）
# .agents/
# .claude/
# .cursor/

# AI 生成的临时文件
.ai-temp/


# ============================================
# 其他
# ============================================

# 压缩文件
*.zip
*.tar.gz
*.rar
*.7z

# 大文件
*.mp4
*.mov
*.avi
*.mkv
*.pdf
*.psd

# 敏感信息
secrets/
private/
*.key
*.pem
*.cert
